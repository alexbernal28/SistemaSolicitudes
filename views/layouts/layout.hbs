<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Solicitudes</title>

    <link rel="stylesheet" href="/assets/css/lib/bootstrap/bootstrap.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background-color: #f0f2f5;
            min-height: 100vh;
        }

        .navbar-brand i {
            font-size: 1.3rem;
        }

        .sidebar {
            min-height: calc(100vh - 56px);
            background-color: #fff;
            border-right: 1px solid #dee2e6;
            padding-top: 1.5rem;
        }

        .sidebar .nav-link {
            color: #495057;
            border-radius: 8px;
            margin-bottom: 4px;
            padding: 0.6rem 1rem;
        }

        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            background-color: #e7f1ff;
            color: #0d6efd;
        }

        .sidebar .nav-link i {
            width: 20px;
        }

        .main-content {
            padding: 2rem;
        }
    </style>
</head>

<body>

    {{! ── NAVBAR ── }}
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">

            <a class="navbar-brand fw-semibold" href="/dashboard">
                <i class="bi bi-building me-2"></i>Sistema de Solicitudes
            </a>

            <div class="ms-auto d-flex align-items-center gap-3">
                {{#if isAuthenticated}}
                <span class="text-white opacity-75 small">
                    <i class="bi bi-person-circle me-1"></i>
                    {{user.name}}
                    <span class="badge bg-white text-primary ms-1">{{user.role.name}}</span>
                </span>

                <form action="/logout" method="POST" class="m-0">
                    <button type="submit" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
                    </button>
                </form>
                {{/if}}
            </div>

        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">

            {{! ── SIDEBAR ── }}
            {{#if isAuthenticated}}
            <nav class="col-md-2 d-none d-md-block sidebar">
                <ul class="nav flex-column px-2">

                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">
                            <i class="bi bi-house me-2"></i>Inicio
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/requests">
                            <i class="bi bi-file-earmark-text me-2"></i>Solicitudes
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/requests/new">
                            <i class="bi bi-plus-circle me-2"></i>Nueva Solicitud
                        </a>
                    </li>

                    {{! Solo admin ve estas opciones }}
                    {{#if (eq user.role.name "Admin")}}
                    <hr class="my-2">
                    <li class="nav-item">
                        <a class="nav-link" href="/users">
                            <i class="bi bi-people me-2"></i>Usuarios
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/roles">
                            <i class="bi bi-shield me-2"></i>Roles
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/departments">
                            <i class="bi bi-diagram-3 me-2"></i>Departamentos
                        </a>
                    </li>
                    {{/if}}

                </ul>
            </nav>
            {{/if}}

            {{! ── CONTENIDO PRINCIPAL ── }}
            <main class="col-md-10 main-content">

                {{! Mensajes flash globales }}
                {{#if hasErrors}}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    {{#each errors}}
                    <span>{{this}}</span>
                    {{/each}}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                {{/if}}

                {{#if hasSuccess}}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    {{#each success}}
                    <span>{{this}}</span>
                    {{/each}}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                {{/if}}

                {{{body}}}
            </main>

        </div>
    </div>

    <script src="/assets/js/lib/bootstrap/bootstrap.bundle.min.js"></script>
</body>

</html>