<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-semibold"><i class="bi bi-people me-2 text-primary"></i>Usuarios</h4>
        <small class="text-muted">Gestión de usuarios del sistema</small>
    </div>
    <a href="/users/new" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Nuevo Usuario
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Usuario</th>
                        <th>Rol</th>
                        <th>Departamento</th>
                        <th>Estado</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each users}}
                    <tr>
                        {{! Nombre y username }}
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-semibold"
                                    style="width:38px; height:38px; font-size:15px;">
                                    {{substring name 0 1}}
                                </div>
                                <div>
                                    <div class="fw-medium">{{name}}</div>
                                    <small class="text-muted">@{{username}}</small>
                                </div>
                            </div>
                        </td>

                        {{! Rol }}
                        <td>
                            <span class="badge bg-primary bg-opacity-10 text-primary">
                                {{Role.name}}
                            </span>
                        </td>

                        {{! Departamento }}
                        <td class="text-muted small">
                            <i class="bi bi-building me-1"></i>{{Department.name}}
                        </td>

                        {{! Estado }}
                        <td>
                            {{#if is_active}}
                            <span class="badge bg-success-subtle text-success">
                                <i class="bi bi-circle-fill me-1" style="font-size:8px"></i>Activo
                            </span>
                            {{else}}
                            <span class="badge bg-danger-subtle text-danger">
                                <i class="bi bi-circle-fill me-1" style="font-size:8px"></i>Inactivo
                            </span>
                            {{/if}}
                        </td>

                        {{! Acciones }}
                        <td class="text-end pe-4">
                            <a href="/users/{{id}}/edit" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <form action="/users/{{id}}/toggle" method="POST" class="d-inline">
                                {{#if is_active}}
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Desactivar"
                                    onclick="return confirm('¿Desactivar a {{name}}?')">
                                    <i class="bi bi-person-slash"></i>
                                </button>
                                {{else}}
                                <button type="submit" class="btn btn-sm btn-outline-success" title="Activar">
                                    <i class="bi bi-person-check"></i>
                                </button>
                                {{/if}}
                            </form>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>

            {{! Sin usuarios }}
            {{#unless users.length}}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people" style="font-size:2.5rem"></i>
                <p class="mt-2 mb-0">No hay usuarios registrados</p>
                <a href="/users/new" class="btn btn-primary btn-sm mt-3">
                    Crear primer usuario
                </a>
            </div>
            {{/unless}}
        </div>
    </div>
</div>