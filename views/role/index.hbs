<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-semibold"><i class="bi bi-shield me-2 text-primary"></i>Roles</h4>
        <small class="text-muted">Gestión de roles y permisos del sistema</small>
    </div>
    <a href="/roles/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Nuevo Rol
    </a>
</div>

<div class="row g-3">
    {{#each roles}}
    <div class="col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">

                {{! Header }}
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center"
                            style="width:40px; height:40px;">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-semibold">{{name}}</h6>
                            <small class="text-muted">Nivel {{level}}</small>
                        </div>
                    </div>

                    {{! Badge sistema }}
                    {{#if is_system}}
                    <span class="badge bg-secondary-subtle text-secondary">
                        <i class="bi bi-lock me-1"></i>Sistema
                    </span>
                    {{else}}
                    <span class="badge bg-success-subtle text-success">
                        <i class="bi bi-pencil me-1"></i>Editable
                    </span>
                    {{/if}}
                </div>

                {{! Permisos }}
                <div class="mb-3">
                    <small class="text-muted d-block mb-2">
                        <i class="bi bi-key me-1"></i>{{permissionCount}} permisos asignados
                    </small>
                    <div class="d-flex flex-wrap gap-1">
                        {{#each Permissions}}
                        <span class="badge bg-light text-dark border" style="font-size: 11px;">
                            {{name}}
                        </span>
                        {{/each}}
                        {{#unless Permissions.length}}
                        <small class="text-muted fst-italic">Sin permisos asignados</small>
                        {{/unless}}
                    </div>
                </div>

            </div>

            {{! Acciones }}
            <div class="card-footer bg-transparent border-top-0 pt-0 d-flex gap-2">
                <a href="/roles/{{id}}/edit" class="btn btn-sm btn-outline-secondary flex-grow-1">
                    <i class="bi bi-pencil me-1"></i>Editar
                </a>

                {{#unless is_system}}
                <form action="/roles/{{id}}/delete" method="POST" class="flex-grow-1">
                    <button type="submit" class="btn btn-sm btn-outline-danger w-100"
                        onclick="return confirm('¿Eliminar el rol {{name}}? Esta acción no se puede deshacer.')">
                        <i class="bi bi-trash me-1"></i>Eliminar
                    </button>
                </form>
                {{/unless}}
            </div>

        </div>
    </div>
    {{/each}}

    {{! Sin roles }}
    {{#unless roles.length}}
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5 text-muted">
                <i class="bi bi-shield" style="font-size:2.5rem"></i>
                <p class="mt-2 mb-0">No hay roles registrados</p>
                <a href="/roles/new" class="btn btn-primary btn-sm mt-3">
                    Crear primer rol
                </a>
            </div>
        </div>
    </div>
    {{/unless}}
</div>